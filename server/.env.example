# ─────────────────────────────────────
# 서버 설정
# ─────────────────────────────────────
NODE_ENV=development
PORT=3000
WS_PORT=3001
API_BASE_URL=https://api.pins.kr/v1

# ─────────────────────────────────────
# 데이터베이스 (PostgreSQL + PostGIS)
# ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/spots?schema=public

# ─────────────────────────────────────
# Redis
# ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────
# JWT 인증
# ─────────────────────────────────────
JWT_SECRET=your-256-bit-secret-key-here
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────
# 카카오 OAuth
# ─────────────────────────────────────
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ─────────────────────────────────────
# AWS S3
# ─────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=spots-uploads
AWS_CLOUDFRONT_DOMAIN=cdn.pins.kr

# ─────────────────────────────────────
# Firebase (FCM 푸시 알림)
# ─────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─────────────────────────────────────
# 어드민
# ─────────────────────────────────────
ADMIN_SECRET_KEY=your-admin-secret-key

# ─────────────────────────────────────
# CORS
# ─────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,https://admin.pins.kr

# ─────────────────────────────────────
# Rate Limit
# ─────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
