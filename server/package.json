{
  "name": "pindor-server",
  "version": "1.0.0",
  "description": "Sports Matching Platform API Server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "start:ws": "node dist/websocket.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "seed": "tsx prisma/seed.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test:seed": "tsx tests/seed-test-users.ts",
    "test:matching": "tsx tests/test-matching.ts",
    "test:game": "tsx tests/test-game-flow.ts",
    "test:all": "tsx tests/run-all.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/etag": "^5.2.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.12.0",
    "dotenv": "^17.3.1",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "firebase-admin": "^12.3.0",
    "ioredis": "^5.4.1",
    "jose": "^5.6.3",
    "pg": "^8.20.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.5",
    "typeorm": "^0.3.28",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.31.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
